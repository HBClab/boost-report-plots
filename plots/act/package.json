{
  "name": "act-plots",
  "version": "1.0.0",
  "description": "Accelerometer activity plots 1 & 2 — D3/TypeScript visualization",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "tsx esbuild.config.ts && node scripts/sync-hr-data.mjs",
    "build:server": "tsc --project tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "tsx server/index.ts",
    "dev": "concurrently \"tsx esbuild.config.ts --watch\" \"tsx watch server/index.ts\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "tsx esbuild.config.ts --watch"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.15.0",
    "typescript": "^5.5.2"
  }
}
