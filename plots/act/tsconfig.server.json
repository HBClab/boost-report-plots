{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/server",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": ["server.ts", "server/**/*", "api/**/*", "src/types.ts"],
  "exclude": ["node_modules", "dist"]
}
