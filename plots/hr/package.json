{
  "name": "hr-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx ./esbuild.config.ts --watch & node --import tsx ./server/index.ts",
    "build": "node --import tsx ./esbuild.config.ts && tsc --project tsconfig.json",
    "start": "node --import tsx ./server/index.ts"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.1",
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
